
#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, Режим)

	Движения.ТоварыВРезерве.Записывать = Истина;

	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыВРезерве");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = Товары;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
	Блокировка.Заблокировать();

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РезервированиеТовараТовары.Номенклатура КАК Номенклатура,
		|	СУММА(РезервированиеТовараТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ втТекущийРезерв
		|ИЗ
		|	Документ.РезервированиеТовара.Товары КАК РезервированиеТовараТовары
		|ГДЕ
		|	РезервированиеТовараТовары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	РезервированиеТовараТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыНаОстаткахОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыНаОстаткахОстатки.КоличествоОстаток КАК КоличествоОстаток
		|ПОМЕСТИТЬ втОстатки
		|ИЗ
		|	РегистрНакопления.ТоварыНаОстатках.Остатки(
		|			&Дата,
		|			Номенклатура В
		|				(ВЫБРАТЬ
		|					втТекРезерв.Номенклатура
		|				ИЗ
		|					втТекущийРезерв КАК втТекРезерв)) КАК ТоварыНаОстаткахОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыВРезервеОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыВРезервеОстатки.ВРезервеОстаток КАК ВРезервеОстаток
		|ПОМЕСТИТЬ втРезерв
		|ИЗ
		|	РегистрНакопления.ТоварыВРезерве.Остатки(
		|			&Дата,
		|			Номенклатура В
		|				(ВЫБРАТЬ
		|					втТекРезерв.Номенклатура
		|				ИЗ
		|					втТекущийРезерв КАК втТекРезерв)) КАК ТоварыВРезервеОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втТекущийРезерв.Номенклатура КАК Номенклатура,
		|	втТекущийРезерв.Количество КАК Количество,
		|	ЕСТЬNULL(втРезерв.ВРезервеОстаток, 0) КАК ВРезервеОстаток,
		|	ЕСТЬNULL(втОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток
		|ИЗ
		|	втТекущийРезерв КАК втТекущийРезерв
		|		ЛЕВОЕ СОЕДИНЕНИЕ втОстатки КАК втОстатки
		|		ПО втТекущийРезерв.Номенклатура = втОстатки.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ втРезерв КАК втРезерв
		|		ПО втТекущийРезерв.Номенклатура = втРезерв.Номенклатура";

	Запрос.УстановитьПараметр("Дата", МоментВремени());
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		ОстатокПослеРезерва = Выборка.КоличествоОстаток - Выборка.Количество - Выборка.ВРезервеОстаток;
		Если ОстатокПослеРезерва < 0 Тогда
			Сообщение = СтрШаблон(
				"Не хватает товара %1 для резерва в количестве %2",
				Выборка.Номенклатура,
				-ОстатокПослеРезерва);
			Сообщить(Сообщение);
			Отказ = Истина;
			Продолжить;
		КонецЕсли;

		Движение = Движения.ТоварыВРезерве.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = Дата;
		Движение.Номенклатура = Выборка.Номенклатура;
		Движение.Контрагент = Контрагент;
		Движение.ВРезерве = Выборка.Количество;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
