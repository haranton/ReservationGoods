
#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, Режим)

	Движения.ТоварыВРезерве.Записывать = Истина;
	Движения.ТоварыНаОстатках.Записывать = Истина;

	БлокировкаРезервов = Новый БлокировкаДанных;
	ЭлементБлокировкиРезервов = БлокировкаРезервов.Добавить("РегистрНакопления.ТоварыВРезерве");
	ЭлементБлокировкиРезервов.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировкиРезервов.ИсточникДанных = Товары;
	ЭлементБлокировкиРезервов.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
	БлокировкаРезервов.Заблокировать();

	БлокировкаОстатков = Новый БлокировкаДанных;
	ЭлементБлокировкиОстатков = БлокировкаОстатков.Добавить("РегистрНакопления.ТоварыНаОстатках");
	ЭлементБлокировкиОстатков.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировкиОстатков.ИсточникДанных = Товары;
	ЭлементБлокировкиОстатков.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
	БлокировкаОстатков.Заблокировать();

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПродажаТовара.Номенклатура КАК Номенклатура,
		|	СУММА(ПродажаТовара.Количество) КАК Количество,
		|	ПродажаТовара.Ссылка.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ ВТТекущаяПродажа
		|ИЗ
		|	Документ.ПродажаТовара.Товары КАК ПродажаТовара
		|ГДЕ
		|	ПродажаТовара.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПродажаТовара.Номенклатура,
		|	ПродажаТовара.Ссылка.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыНаОстаткахОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыНаОстаткахОстатки.КоличествоОстаток КАК КоличествоОстаток
		|ПОМЕСТИТЬ ВТОстатки
		|ИЗ
		|	РегистрНакопления.ТоварыНаОстатках.Остатки(
		|			&Дата,
		|			Номенклатура В
		|				(ВЫБРАТЬ
		|					ВТТекущаяПродажа.Номенклатура
		|				ИЗ
		|					ВТТекущаяПродажа КАК ВТТекущаяПродажа)) КАК ТоварыНаОстаткахОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыВРезервеОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыВРезервеОстатки.ВРезервеОстаток КАК ВРезервеОстаток,
		|	ТоварыВРезервеОстатки.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ ВТРезервКонтрагента
		|ИЗ
		|	РегистрНакопления.ТоварыВРезерве.Остатки(
		|			&Дата,
		|			Номенклатура В
		|					(ВЫБРАТЬ
		|						ВТТекущаяПродажа.Номенклатура
		|					ИЗ
		|						ВТТекущаяПродажа КАК ВТТекущаяПродажа)
		|				И Контрагент = &Контрагент) КАК ТоварыВРезервеОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыВРезервеОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыВРезервеОстатки.ВРезервеОстаток КАК ВРезервеОстаток
		|ПОМЕСТИТЬ ВТРезервОбщий
		|ИЗ
		|	РегистрНакопления.ТоварыВРезерве.Остатки(
		|			&Дата,
		|			Номенклатура В
		|				(ВЫБРАТЬ
		|					ВТТекущаяПродажа.Номенклатура
		|				ИЗ
		|					ВТТекущаяПродажа КАК ВТТекущаяПродажа)) КАК ТоварыВРезервеОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТекущаяПродажа.Номенклатура КАК Номенклатура,
		|	ВТТекущаяПродажа.Количество КАК Количество,
		|	ЕСТЬNULL(ВТРезервОбщий.ВРезервеОстаток, 0) КАК ВРезервеОстатокОбщий,
		|	ЕСТЬNULL(ВТРезервКонтрагента.ВРезервеОстаток, 0) КАК ВРезервеОстатокКонтрагента,
		|	ЕСТЬNULL(ВТОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток
		|ИЗ
		|	ВТТекущаяПродажа КАК ВТТекущаяПродажа
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстатки КАК ВТОстатки
		|		ПО ВТТекущаяПродажа.Номенклатура = ВТОстатки.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРезервОбщий КАК ВТРезервОбщий
		|		ПО ВТТекущаяПродажа.Номенклатура = ВТРезервОбщий.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРезервКонтрагента КАК ВТРезервКонтрагента
		|		ПО ВТТекущаяПродажа.Номенклатура = ВТРезервКонтрагента.Номенклатура";

	Запрос.УстановитьПараметр("Дата", МоментВремени());
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		ОстатокПослеПродажи = Выборка.КоличествоОстаток
			+ Выборка.ВРезервеОстатокКонтрагента
			- Выборка.Количество
			- Выборка.ВРезервеОстатокОбщий;
		Если ОстатокПослеПродажи < 0 Тогда
			Сообщение = СтрШаблон(
				"Не хватает товара %1 для продажи в количестве %2",
				Выборка.Номенклатура,
				-ОстатокПослеПродажи);
			Сообщить(Сообщение);
			Отказ = Истина;
			Продолжить;
		КонецЕсли;

		Если Выборка.ВРезервеОстатокКонтрагента > 0 Тогда
			КоличествоРезерв = Мин(Выборка.ВРезервеОстатокКонтрагента, Выборка.Количество);

			ДвижениеРезерва = Движения.ТоварыВРезерве.Добавить();
			ДвижениеРезерва.ВидДвижения = ВидДвиженияНакопления.Расход;
			ДвижениеРезерва.Период = Дата;
			ДвижениеРезерва.Номенклатура = Выборка.Номенклатура;
			ДвижениеРезерва.Контрагент = Контрагент;
			ДвижениеРезерва.ВРезерве = КоличествоРезерв;
		КонецЕсли;

		ДвижениеОстатков = Движения.ТоварыНаОстатках.Добавить();
		ДвижениеОстатков.ВидДвижения = ВидДвиженияНакопления.Расход;
		ДвижениеОстатков.Период = Дата;
		ДвижениеОстатков.Номенклатура = Выборка.Номенклатура;
		ДвижениеОстатков.Количество = Выборка.Количество;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
