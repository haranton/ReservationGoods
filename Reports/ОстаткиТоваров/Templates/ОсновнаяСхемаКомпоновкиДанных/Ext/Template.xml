		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ТоварыНаОстаткахОстатки.Номенклатура КАК Номенклатура,
	ТоварыНаОстаткахОстатки.КоличествоОстаток КАК КоличествоОстаток
ПОМЕСТИТЬ втОстатки
ИЗ
	РегистрНакопления.ТоварыНаОстатках.Остатки КАК ТоварыНаОстаткахОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТоварыВРезервеОстатки.Номенклатура КАК Номенклатура,
	ТоварыВРезервеОстатки.ВРезервеОстаток КАК ВРезервеОстаток
ПОМЕСТИТЬ втРезерв
ИЗ
	РегистрНакопления.ТоварыВРезерве.Остатки КАК ТоварыВРезервеОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втОстатки.Номенклатура КАК Номенклатура,
	втОстатки.КоличествоОстаток КАК Остаток,
	ЕСТЬNULL(втРезерв.ВРезервеОстаток, 0) КАК ВРезерве,
	втОстатки.КоличествоОстаток - ЕСТЬNULL(втРезерв.ВРезервеОстаток, 0) КАК СвободныйОстаток
ИЗ
	втОстатки КАК втОстатки
		ЛЕВОЕ СОЕДИНЕНИЕ втРезерв КАК втРезерв
		ПО втОстатки.Номенклатура = втРезерв.Номенклатура</query>
